{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "networkInterfaces_webserver271_z1_name": {
            "defaultValue": "webserver271_z1",
            "type": "String"
        },
        "publicIPAddresses_webserver_ip_externalid": {
            "defaultValue": "/subscriptions/c516e71f-6d47-4e41-896d-44295e620ec3/resourceGroups/My-Group/providers/Microsoft.Network/publicIPAddresses/webserver-ip",
            "type": "String"
        },
        "virtualNetworks_vnet_koreacentral_externalid": {
            "defaultValue": "/subscriptions/c516e71f-6d47-4e41-896d-44295e620ec3/resourceGroups/My-Group/providers/Microsoft.Network/virtualNetworks/vnet-koreacentral",
            "type": "String"
        },
        "applicationSecurityGroups_asg_web_externalid": {
            "defaultValue": "/subscriptions/c516e71f-6d47-4e41-896d-44295e620ec3/resourceGroups/My-Group/providers/Microsoft.Network/applicationSecurityGroups/asg-web",
            "type": "String"
        },
        "networkSecurityGroups_webserver_nsg_externalid": {
            "defaultValue": "/subscriptions/c516e71f-6d47-4e41-896d-44295e620ec3/resourceGroups/My-Group/providers/Microsoft.Network/networkSecurityGroups/webserver-nsg",
            "type": "String"
        }
    },
    "variables": {},
    "resources": [
        {
            "type": "Microsoft.Network/networkInterfaces",
            "apiVersion": "2024-07-01",
            "name": "[parameters('networkInterfaces_webserver271_z1_name')]",
            "location": "koreacentral",
            "kind": "Regular",
            "properties": {
                "ipConfigurations": [
                    {
                        "name": "ipconfig1",
                        "id": "[concat(resourceId('Microsoft.Network/networkInterfaces', parameters('networkInterfaces_webserver271_z1_name')), '/ipConfigurations/ipconfig1')]",
                        "type": "Microsoft.Network/networkInterfaces/ipConfigurations",
                        "properties": {
                            "privateIPAddress": "172.16.0.4",
                            "privateIPAllocationMethod": "Dynamic",
                            "publicIPAddress": {
                                "id": "[parameters('publicIPAddresses_webserver_ip_externalid')]",
                                "properties": {
                                    "deleteOption": "Detach"
                                }
                            },
                            "subnet": {
                                "id": "[concat(parameters('virtualNetworks_vnet_koreacentral_externalid'), '/subnets/snet-koreacentral-1')]"
                            },
                            "primary": true,
                            "privateIPAddressVersion": "IPv4",
                            "applicationSecurityGroups": [
                                {
                                    "id": "[parameters('applicationSecurityGroups_asg_web_externalid')]"
                                }
                            ]
                        }
                    }
                ],
                "dnsSettings": {
                    "dnsServers": []
                },
                "enableAcceleratedNetworking": true,
                "enableIPForwarding": false,
                "disableTcpStateTracking": false,
                "networkSecurityGroup": {
                    "id": "[parameters('networkSecurityGroups_webserver_nsg_externalid')]"
                },
                "nicType": "Standard",
                "auxiliaryMode": "None",
                "auxiliarySku": "None"
            }
        }
    ]
}